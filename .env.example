# Risk Monitoring System - Docker Environment Template
# Copy this file to .env and customize for your environment
# IMPORTANT: Change all passwords and secrets before deploying to production

# ==================================================================================
# DATABASE CONFIGURATION
# ==================================================================================
DB_USER=riskmonitor
DB_PASSWORD=secure_password_change_me
DB_NAME=risk_monitoring_db
DB_DDL_AUTO=validate

# ==================================================================================
# AUTHENTICATION & JWT CONFIGURATION
# CRITICAL: Generate strong secrets for production
# Generate with: openssl rand -base64 32
# ==================================================================================
JWT_SECRET=your-super-secret-jwt-key-at-least-256-bits-long-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-at-least-256-bits-long-change
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ==================================================================================
# IBM MQ CONFIGURATION
# ==================================================================================
MQ_USER=app
MQ_PASSWORD=passw0rd_change_me
MQ_ADMIN_PASSWORD=passw0rd_change_me

# ==================================================================================
# SPRING CONFIGURATION
# ==================================================================================
# Profile options: docker, development, production
SPRING_PROFILES_ACTIVE=docker

# ==================================================================================
# RISK ANALYSIS THRESHOLDS
# ==================================================================================
# Values between 0.0 and 1.0
RISK_THRESHOLD_HIGH=0.8
RISK_THRESHOLD_MEDIUM=0.5

# ==================================================================================
# SECURITY HEADERS & CORS
# ==================================================================================
# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Production: CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Enable HTTPS only (set to true in production)
SERVER_SSL_ENABLED=false
SERVER_SSL_KEYSTORE_PATH=/path/to/keystore.p12
SERVER_SSL_KEYSTORE_PASSWORD=change_me
SERVER_SSL_KEYSTORE_TYPE=PKCS12

# ==================================================================================
# APPLICATION CONFIGURATION
# ==================================================================================
APP_LOG_LEVEL=INFO
APP_SERVER_TIMEOUT=30000

# ==================================================================================
# DATABASE CONNECTION POOL
# ==================================================================================
DB_POOL_SIZE=10
DB_IDLE_TIMEOUT=900
DB_MAX_LIFETIME=1200

# ==================================================================================
# JVM CONFIGURATION
# ==================================================================================
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:+UseStringDeduplication

# ==================================================================================
# CONTAINER REGISTRY (for production deployments)
# ==================================================================================
# DOCKER_REGISTRY=your-registry.azurecr.io
# DOCKER_USERNAME=your-username
# DOCKER_PASSWORD=your-password

# ==================================================================================
# SERVICE REPLICAS (for Docker Swarm/Kubernetes)
# ==================================================================================
# PRODUCER_SERVICE_REPLICAS=3
# RISK_ENGINE_REPLICAS=2
# ALERT_SERVICE_REPLICAS=2

# ==================================================================================
# MONITORING AND LOGGING
# ==================================================================================
# MONITORING_ENABLED=true
# METRICS_PORT=9090
# ELK_STACK_ENABLED=false

# ==================================================================================
# EMAIL CONFIGURATION (for password reset and email verification)
# ==================================================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@riskmonitoring.com
MAIL_ENABLE_TLS=true

# ==================================================================================
# SECURITY LOGGING
# ==================================================================================
# Enable audit logging for security events
AUDIT_LOG_ENABLED=true
SECURITY_LOG_LEVEL=INFO
