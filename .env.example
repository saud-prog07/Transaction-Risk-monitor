# ============================================================================
# RISK MONITORING SYSTEM - ENVIRONMENT TEMPLATE
# ============================================================================
# This file serves as a template for environment configuration
# 
# ⚠️  IMPORTANT: DO NOT COMMIT .env WITH ACTUAL SECRETS TO GITHUB
# This file documents what environment variables are needed
# 
# For production deployment:
# 1. Generate strong, unique values for each secret
# 2. Store in: AWS Secrets Manager / HashiCorp Vault / Azure Key Vault
# 3. Inject at runtime (don't use .env files in production)
# ============================================================================

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=risk_monitoring_db
DB_USER=app_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN
DB_POOL_SIZE=100
DB_MIN_IDLE=20
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# ==============================================================================
# MESSAGE QUEUE (IBM MQ ENTERPRISE)
# ==============================================================================
MQ_HOST=ibm-mq
MQ_PORT=1414
MQ_QUEUE_MANAGER=QMGR
MQ_CHANNEL=ALERT.CHANNEL
MQ_USER=app
MQ_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN
MQ_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN

# ==============================================================================
# REDIS CACHE (DISTRIBUTED CACHING)
# ==============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN
REDIS_DATABASE=0
REDIS_TIMEOUT=2000

# ==============================================================================
# SECURITY & JWT AUTHENTICATION
# ==============================================================================
# Generated with: openssl rand -base64 32
# Must be different for each environment
JWT_SECRET=CHANGE_ME_TO_BASE64_32_BYTE_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_BASE64_32_BYTE_RANDOM_STRING
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# ==============================================================================
# APPLICATION ENVIRONMENT
# ==============================================================================
# Options: development | staging | production
SPRING_PROFILES_ACTIVE=development
ENVIRONMENT=development
APP_NAME=risk-monitoring-system
APP_VERSION=1.0.0

# ==============================================================================
# LOGGING CONFIGURATION
# ==============================================================================
LOG_LEVEL=INFO
LOGGING_LEVEL_ROOT=WARN
LOGGING_LEVEL_COM_RISKTRANSACTION=INFO

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ==============================================================================
# MONITORING & METRICS
# ==============================================================================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,metrics,prometheus,info,env
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true
MANAGEMENT_ENDPOINT_HEALTH_PROBES_ENABLED=true

# ==============================================================================
# RATE LIMITING CONFIGURATION
# ==============================================================================
# Per-minute rate limits for different endpoint types
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_AUTH=5
RATE_LIMIT_AUTHENTICATED=1000

# ==============================================================================
# OPTIONAL: EXTERNAL SERVICES (If integrated)
# ==============================================================================
# Email notifications
EMAIL_SERVICE_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=CHANGE_ME
EMAIL_PASSWORD=CHANGE_ME

# Slack notifications
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==============================================================================
# PRODUCTION DEPLOYMENT NOTES
# ==============================================================================
# 
# 1. PASSWORD GENERATION (Run these commands):
#    Windows:
#      certutil -seeding 8192 && powershell "$([System.Web.Security.Membership]::GeneratePassword(32,8))"
#    
#    Linux/Mac:
#      openssl rand -base64 32
#    
#    Python:
#      python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 2. SECURE STORAGE:
#    ✓ AWS Secrets Manager - Recommended for AWS deployments
#    ✓ HashiCorp Vault - Recommended for on-premise/multi-cloud
#    ✓ Azure Key Vault - Recommended for Azure deployments
#    ✓ Kubernetes Secrets - For Kubernetes deployments
#
# 3. SECRET ROTATION:
#    - Rotate all secrets every 90 days
#    - Implement zero-downtime rotation
#    - Test rotation process quarterly
#
# 4. AUDIT LOGGING:
#    - Enable audit logging for all secret access
#    - Monitor for unauthorized access attempts
#    - Set up alerts for failed authentication
#
# ============================================================================

# SPRING CONFIGURATION
# ==================================================================================
# Profile options: docker, development, production
SPRING_PROFILES_ACTIVE=docker

# ==================================================================================
# RISK ANALYSIS THRESHOLDS
# ==================================================================================
# Values between 0.0 and 1.0
RISK_THRESHOLD_HIGH=0.8
RISK_THRESHOLD_MEDIUM=0.5

# ==================================================================================
# SECURITY HEADERS & CORS
# ==================================================================================
# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Production: CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Enable HTTPS only (set to true in production)
SERVER_SSL_ENABLED=false
SERVER_SSL_KEYSTORE_PATH=/path/to/keystore.p12
SERVER_SSL_KEYSTORE_PASSWORD=change_me
SERVER_SSL_KEYSTORE_TYPE=PKCS12

# ==================================================================================
# APPLICATION CONFIGURATION
# ==================================================================================
APP_LOG_LEVEL=INFO
APP_SERVER_TIMEOUT=30000

# ==================================================================================
# DATABASE CONNECTION POOL
# ==================================================================================
DB_POOL_SIZE=10
DB_IDLE_TIMEOUT=900
DB_MAX_LIFETIME=1200

# ==================================================================================
# JVM CONFIGURATION
# ==================================================================================
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:+UseStringDeduplication

# ==================================================================================
# CONTAINER REGISTRY (for production deployments)
# ==================================================================================
# DOCKER_REGISTRY=your-registry.azurecr.io
# DOCKER_USERNAME=your-username
# DOCKER_PASSWORD=your-password

# ==================================================================================
# SERVICE REPLICAS (for Docker Swarm/Kubernetes)
# ==================================================================================
# PRODUCER_SERVICE_REPLICAS=3
# RISK_ENGINE_REPLICAS=2
# ALERT_SERVICE_REPLICAS=2

# ==================================================================================
# MONITORING AND LOGGING
# ==================================================================================
# MONITORING_ENABLED=true
# METRICS_PORT=9090
# ELK_STACK_ENABLED=false

# ==================================================================================
# EMAIL CONFIGURATION (for password reset and email verification)
# ==================================================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@riskmonitoring.com
MAIL_ENABLE_TLS=true

# ==================================================================================
# SECURITY LOGGING
# ==================================================================================
# Enable audit logging for security events
AUDIT_LOG_ENABLED=true
SECURITY_LOG_LEVEL=INFO
