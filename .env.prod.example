# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this to .env.prod and fill in with ACTUAL secure values
# NEVER commit .env.prod to version control
# ============================================================================

# ============================================================================
# Database Configuration
# ============================================================================
DB_USER=postgres
DB_PASSWORD=GENERATE_WITH_openssl_rand_-base64_32
DB_NAME=alert_db
DB_PORT=5432

# ============================================================================
# Message Queue (RabbitMQ)
# ============================================================================
MQ_USER=admin
MQ_PASSWORD=GENERATE_WITH_openssl_rand_-base64_32
MQ_ADMIN_PASSWORD=GENERATE_WITH_openssl_rand_-base64_32
MQ_PORT=5672

# ============================================================================
# Redis Cache
# ============================================================================
REDIS_PASSWORD=GENERATE_WITH_openssl_rand_-base64_32
REDIS_PORT=6379

# ============================================================================
# JWT Security
# ============================================================================
JWT_SECRET=GENERATE_WITH_openssl_rand_-base64_32
JWT_REFRESH_SECRET=GENERATE_WITH_openssl_rand_-base64_32
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ============================================================================
# SSL/TLS Configuration
# ============================================================================
SSL_KEYSTORE_PATH=/path/to/keystore.p12
KEYSTORE_PASSWORD=GENERATE_WITH_openssl_rand_-base64_24
SSL_CERT_PATH=/path/to/certificate.crt
SSL_KEY_PATH=/path/to/private.key

# ============================================================================
# Domain & CORS
# ============================================================================
API_DOMAIN=api.yourdomain.com
FRONTEND_DOMAIN=yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_HOSTS=api.yourdomain.com,yourdomain.com

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_BURST=10

# ============================================================================
# Logging Configuration
# ============================================================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_APPLICATION=DEBUG
LOG_PATH=/var/log/alert-service
LOG_FILE_MAX_SIZE=50m
LOG_FILE_MAX_HISTORY=5

# ============================================================================
# Email/Notifications (for alerts)
# ============================================================================
NOTIFICATION_EMAIL_HOST=smtp.yourdomain.com
NOTIFICATION_EMAIL_PORT=587
NOTIFICATION_EMAIL_USERNAME=alerts@yourdomain.com
NOTIFICATION_EMAIL_PASSWORD=GENERATE_WITH_openssl_rand_-base64_32
NOTIFICATION_EMAIL_FROM=alerts@yourdomain.com

# ============================================================================
# Security Settings
# ============================================================================
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_CSP_ENABLED=true
SECURITY_CORS_ENABLED=true

# ============================================================================
# Database Connection Pool
# ============================================================================
DB_POOL_SIZE=20
DB_MAX_LIFETIME=1800000
DB_IDLE_TIMEOUT=600000
DB_VALIDATION_QUERY=SELECT 1

# ============================================================================
# Actuator (Health Checks)
# ============================================================================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized
MANAGEMENT_METRICS_ENABLED=true

# ============================================================================
# Application Profiles
# ============================================================================
SPRING_PROFILES_ACTIVE=prod
ENVIRONMENT=production

# ============================================================================
# Deployment Information
# ============================================================================
DEPLOYMENT_VERSION=1.0.0
DEPLOYMENT_BUILD_NUMBER=0
DEPLOYMENT_TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
DEPLOYMENT_HOST=docker-host.yourdomain.com

# ============================================================================
# Backup & Recovery
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=backups-yourdomain-prod
BACKUP_S3_REGION=us-east-1

# ============================================================================
# Monitoring & Alerting
# ============================================================================
DATADOG_ENABLED=false
DATADOG_API_KEY=YOUR_API_KEY
SENTRY_ENABLED=true
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production

# ============================================================================
# IMPORTANT NOTES
# ============================================================================
# 1. Generate all passwords using: openssl rand -base64 32
# 2. Keep this file secure and NEVER commit to git
# 3. Use secrets management for production (Vault, AWS Secrets Manager, etc.)
# 4. Rotate JWT secrets periodically (at least quarterly)
# 5. Rotate database passwords at least annually
# 6. Replace all "yourdomain.com" with your actual domain
# 7. Enable MFA for admin accounts
# 8. Enable audit logging for all services
# 9. Set up monitoring and alerting for security events
# 10. Document all security policies and procedures
