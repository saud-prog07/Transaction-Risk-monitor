# ==========================================
# SECURITY HARDENING - ENVIRONMENT VARIABLES
# ==========================================
# This file contains all security-sensitive environment variables that should be configured.
# NEVER commit actual keys/secrets - use this as a template.
# Each environment (dev, staging, prod) should have its own .env file.

# ==========================================
# JWT CONFIGURATION (REQUIRED)
# ==========================================
# Secret key for signing JWT tokens
# Generate with: openssl rand -base64 32 (minimum 256 bits)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-base64-encoded
JWT_EXPIRATION=3600000

# Secret key for signing refresh tokens
# Generate with: openssl rand -base64 32 (minimum 256 bits)
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-base64-encoded
JWT_REFRESH_EXPIRATION=604800000

# ==========================================
# API KEYS FOR EXTERNAL SERVICES (REQUIRED)
# ==========================================
# Risk Engine Service API Key
# Used for authenticating calls to the risk-engine microservice
API_RISK_ENGINE_KEY=risk-engine-api-key-from-secure-vault

# Alert Notification Service API Key
# Used for external notification services (Slack, PagerDuty, etc.)
API_ALERT_NOTIFICATION_KEY=notification-api-key-from-secure-vault

# External Third-Party Service Key
# Used for any external integrations
API_EXTERNAL_SERVICE_KEY=external-service-key-from-secure-vault

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# PostgreSQL database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/transaction_risk_db
SPRING_DATASOURCE_USERNAME=risk_user
SPRING_DATASOURCE_PASSWORD=secure-database-password-here

# ==========================================
# MESSAGE QUEUE CONFIGURATION
# ==========================================
# IBM MQ Connection
MQ_BROKER_URL=tcp://localhost:1414
MQ_CHANNEL=DEV.APP.SVRCONN
MQ_QUEUE_MANAGER=QM1
MQ_USER=admin
MQ_PASSWORD=mq-password-here

# ==========================================
# REDIS CACHE (OPTIONAL)
# ==========================================
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=redis-password-here

# ==========================================
# RATE LIMITING CONFIGURATION
# ==========================================
# Global rate limit for public endpoints (requests per minute)
RATE_LIMIT_PUBLIC_REQUESTS_PER_MINUTE=100

# Rate limit for auth endpoints (requests per minute) - stricter to prevent brute force
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=5

# Rate limit for authenticated endpoints (requests per minute)
RATE_LIMIT_AUTHENTICATED_REQUESTS_PER_MINUTE=1000

# ==========================================
# CORS CONFIGURATION
# ==========================================
# Allowed origins for CORS (comma-separated)
# In production, specify exact domain(s)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
# Logging level (DEBUG, INFO, WARN, ERROR)
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_EXAMPLE_RISKMONITORING=DEBUG
LOGGING_LEVEL_SECURITY=DEBUG

# ==========================================
# SECURITY HEADERS
# ==========================================
# Enable HSTS (HTTP Strict Transport Security)
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000

# ==========================================
# SESSION CONFIGURATION
# ==========================================
# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30

# ==========================================
# DEPLOYMENT ENVIRONMENT
# ==========================================
# Environment (dev, staging, prod)
ENVIRONMENT=development

# Profile for Spring
SPRING_PROFILES_ACTIVE=dev

# ==========================================
# NOTES FOR DEPLOYMENT
# ==========================================
# 1. NEVER commit this file with actual values
# 2. Use .env.local or .env.{environment} for actual values
# 3. In production, use AWS Secrets Manager, Azure Key Vault, or HashiCorp Vault
# 4. Keys should be rotated regularly (at least quarterly)
# 5. Keys should be at least 256 bits (32 characters base64)
# 6. Different keys for different environments
# 7. Audit key access and rotation
# 8. Use environment-specific configuration:
#    - Development: Less strict policies for testing
#    - Staging: Mirrors production
#    - Production: Maximum security, longest expiration on rotation
